{
  "name": "tokenhandler",
  "version": "1.0.0",
  "description": "A custom serverless token handler implementation for the Final SPA",
  "author": "Gary Archer",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "login": "sls login",
    "lint": "npx eslint . --ignore-pattern dist",
    "build": "rm -rf dist && tsc",
    "buildRelease": "rimraf dist && tsc --sourceMap false",
    "start": "./start.sh",
    "test": "./start.sh",
    "deployDev": "./deploy.sh dev",
    "deploy": "./deploy.sh deployed",
    "httpDev": "./test/runHttpWorkflow.sh dev",
    "http": "./test/runHttpWorkflow.sh deployed",
    "removeDev": "sls remove --stage dev",
    "remove": "sls remove --stage deployed"
  },
  "dependencies": {
    "@middy/core": "^6.1.5",
    "axios": "^1.8.3",
    "cookie": "^1.0.1",
    "fs-extra": "^11.3.0",
    "jose": "^6.0.10"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@types/aws-lambda": "^8.10.145",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.16.13",
    "eslint": "^9.22.0",
    "https-proxy-agent": "^7.0.5",
    "serverless": "^4.7.0",
    "serverless-domain-manager": "8.0.0",
    "typescript": "^5.8",
    "typescript-eslint": "^8.26.1"
  }
}
