{
  "name": "tokenhandler",
  "version": "1.0.0",
  "description": "An AWS serverless token handler with low cost hosting for my blog's Final SPA",
  "author": "Gary Archer",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "lint": "eslint .",
    "buildRelease": "NODE_OPTIONS='--import tsx' npx webpack --config webpack/webpack.config.ts",
    "deployDev": "./deploy.sh dev",
    "deploy": "./deploy.sh deployed",
    "removeDev": "sls remove --stage dev",
    "remove": "sls remove --stage deployed"
  },
  "dependencies": {
    "@middy/core": "^6.4.5",
    "cookie": "^1.1.1",
    "jose": "^6.2.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/aws-lambda": "^8.10.159",
    "@types/node": "^24.10.3",
    "eslint": "^10.1.0",
    "serverless": "^4.33.0",
    "serverless-domain-manager": "10.0.0",
    "ts-loader": "^9.5.4",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "webpack": "^5.105.4",
    "webpack-cli": "^6.0.1"
  }
}
